<%- include('../partials/admin-header', { pageTitle: listing ? t('edit') : t('add_new_listing'), active: listing ? 'listings' : 'new-listing' }) %>

<h1 class="section-title"><%= listing ? t('edit') : t('add_new_listing') %></h1>

<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<form class="form-card" style="max-width:640px;" method="post"
      action="<%= listing ? '/admin/listings/' + listing.id + '/edit' : '/admin/listings/new' %>"
      enctype="multipart/form-data">

  <div class="form-group">
    <label><%= t('category') %></label>
    <select name="category" id="categorySelect" required>
      <option value=""><%= t('select_category') %></option>
      <% categories.forEach(function(cat) { %>
        <option value="<%= cat.slug %>"
          data-location="<%= cat.hasLocation %>"
          data-area="<%= cat.hasArea %>"
          <%= listing && listing.category === cat.slug ? 'selected' : '' %>>
          <%= cat.icon %> <%= cat.name.en %> / <%= cat.name.am %>
        </option>
      <% }) %>
    </select>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label><%= t('title_en') %></label>
      <input type="text" name="title_en" required value="<%= listing ? listing.title_en : '' %>">
    </div>
    <div class="form-group">
      <label><%= t('title_am') %></label>
      <input type="text" name="title_am" required value="<%= listing ? listing.title_am : '' %>">
    </div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label><%= t('description_en') %></label>
      <textarea name="description_en"><%= listing ? listing.description_en : '' %></textarea>
    </div>
    <div class="form-group">
      <label><%= t('description_am') %></label>
      <textarea name="description_am"><%= listing ? listing.description_am : '' %></textarea>
    </div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label><%= t('price') %> (ETB)</label>
      <input type="number" name="price" min="0" step="0.01" value="<%= listing && listing.price ? listing.price : '' %>" placeholder="<%= t('negotiable') %>">
    </div>
    <div class="form-group">
      <label><%= t('price_type') %></label>
      <select name="priceType">
        <option value="fixed" <%= listing && listing.priceType === 'fixed' ? 'selected' : '' %>><%= t('fixed_price') %></option>
        <option value="negotiable" <%= listing && listing.priceType === 'negotiable' ? 'selected' : '' %>><%= t('negotiable') %></option>
      </select>
    </div>
  </div>

  <div class="form-group" id="locationGroup" style="display:none;">
    <label><%= t('location') %></label>
    <select name="location">
      <option value=""><%= t('select_location') %></option>
      <% HOSSANA_AREAS.forEach(function(area) { %>
        <option value="<%= area %>" <%= listing && listing.location === area ? 'selected' : '' %>><%= area %></option>
      <% }) %>
    </select>
  </div>

  <div class="form-row" id="areaGroup" style="display:none;">
    <div class="form-group">
      <label><%= t('area_size') %></label>
      <input type="number" name="areaSize" min="0" step="0.01" value="<%= listing && listing.areaSize ? listing.areaSize : '' %>">
    </div>
    <div class="form-group">
      <label><%= t('area_unit') %></label>
      <select name="areaUnit">
        <option value="sqm" <%= listing && listing.areaUnit === 'sqm' ? 'selected' : '' %>><%= t('square_meters') %></option>
        <option value="km2" <%= listing && listing.areaUnit === 'km2' ? 'selected' : '' %>><%= t('square_kilometers') %></option>
      </select>
      <small style="color:var(--text-muted); font-size:0.75rem;"><%= t('km2_note') %></small>
    </div>
  </div>

  <% if (listing) { %>
    <div class="form-group">
      <label><%= t('booking_status') %></label>
      <select name="status">
        <option value="available" <%= listing.status === 'available' ? 'selected' : '' %>><%= t('status_available') %></option>
        <option value="sold" <%= listing.status === 'sold' ? 'selected' : '' %>><%= t('status_sold') %></option>
        <option value="rented" <%= listing.status === 'rented' ? 'selected' : '' %>><%= t('status_rented') %></option>
      </select>
    </div>
    <% if (listing.images && listing.images.length > 0) { %>
      <div class="form-group">
        <label><%= t('images') %></label>
        <div class="image-upload-preview">
          <% listing.images.forEach(function(img) { %>
            <img src="<%= img %>">
          <% }) %>
        </div>
      </div>
    <% } %>
  <% } %>

  <div class="form-group">
    <label><%= t('upload_images') %></label>
    <input type="file" name="images" accept="image/*" multiple>
  </div>

  <button type="submit" class="btn btn-primary btn-block"><%= t('save_listing') %></button>
</form>

<script>
  const categorySelect = document.getElementById('categorySelect');
  const locationGroup = document.getElementById('locationGroup');
  const areaGroup = document.getElementById('areaGroup');

  function updateFields() {
    const opt = categorySelect.options[categorySelect.selectedIndex];
    if (!opt) return;
    const hasLocation = opt.getAttribute('data-location') === 'true';
    const hasArea = opt.getAttribute('data-area') === 'true';
    locationGroup.style.display = hasLocation ? 'block' : 'none';
    areaGroup.style.display = hasArea ? 'grid' : 'none';
  }

  categorySelect.addEventListener('change', updateFields);
  updateFields();
</script>

<%- include('../partials/admin-footer') %>
