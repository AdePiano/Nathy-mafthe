<%- include('partials/header', { pageTitle: null }) %>

<section class="hero">
  <div class="hero-inner">
    <h1><%= t('home_hero_title') %></h1>
    <p><%= t('home_hero_subtitle') %></p>
    <a href="#categories" class="btn btn-primary"><%= t('browse_categories') %></a>
  </div>
</section>

<section class="section" id="categories">
  <h2 class="section-title"><%= t('browse_categories') %></h2>
  <div class="category-grid">
    <% categories.forEach(function(cat) { %>
      <a class="category-card" href="/category/<%= cat.slug %>">
        <div class="category-icon"><%= cat.icon %></div>
        <div class="category-name-am"><%= lang === 'am' ? cat.name.am : cat.name.en %></div>
        <div class="category-name-en"><%= lang === 'am' ? cat.name.en : '' %></div>
      </a>
    <% }) %>
  </div>
</section>

<section class="section">
  <h2 class="section-title"><%= t('featured_listings') %></h2>
  <% if (latest.length === 0) { %>
    <div class="empty-state"><%= t('no_listings') %></div>
  <% } else { %>
    <div class="listing-grid">
      <% latest.forEach(function(listing) {
           const cat = getCategory(listing.category);
      %>
        <a class="listing-card" href="/listing/<%= listing.id %>">
          <div class="listing-thumb">
            <% if (listing.images && listing.images.length > 0) { %>
              <img src="<%= listing.images[0] %>" alt="<%= listing.title_en %>">
            <% } %>
            <span class="badge badge-<%= listing.status %>"><%= t('status_' + listing.status) %></span>
          </div>
          <div class="listing-body">
            <div class="listing-title"><%= lang === 'am' ? listing.title_am : listing.title_en %></div>
            <div class="listing-title-sub"><%= cat ? (lang === 'am' ? cat.name.am : cat.name.en) : '' %></div>
            <% if (listing.location) { %>
              <div class="listing-meta">📍 <%= listing.location %></div>
            <% } %>
            <div class="listing-price">
              <% if (listing.price) { %>
                <%= Number(listing.price).toLocaleString() %> ETB
                <% if (cat && cat.type === 'rent') { %><small><%= t('per_day') %></small><% } %>
              <% } else { %>
                <small><%= t('negotiable') %></small>
              <% } %>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>
